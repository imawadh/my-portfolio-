---
import PageLayout from '../../layouts/PageLayout.astro';
import ProjectCard from '../../components/ProjectCard.astro';

const professionalProjects = [
  {
    name: 'The SRS Classes',
    description: 'An ed-tech platform for BPSC and other competitive exams — courses, mock tests, and progress tracking in one place.',
    tags: ['Next.js', 'Tailwind', 'MongoDB', 'Node.js'],
    live: 'https://thesrsclasses.com',
    code: 'https://github.com/imawadh/srs-website',
    caseStudy: '/projects/srs-classes',
    image: 'https://picsum.photos/800/400?random=4',
  },
];
---

<PageLayout
  title="Projects — Awadh Kishor Singh"
  description="Projects built by Awadh Kishor Singh — full stack web applications including SRS Classes."
>
  <section class="container mx-auto px-6 py-16 md:px-8 md:py-24">
    <span class="eyebrow">Selected work</span>
    <h1 class="mb-3 text-4xl font-semibold tracking-tight text-[var(--fg)] md:text-5xl">
      Things I've built
    </h1>
    <p class="mb-12 max-w-[640px] text-base text-[var(--muted)] md:text-lg">
      Full-stack applications shipped in production — most with real users, all built end-to-end.
    </p>

    <div class="flex flex-col gap-4">
      <div class="flex items-baseline justify-between gap-4">
        <h2 class="m-0 text-2xl font-semibold text-[var(--fg)]">Professional projects</h2>
        <span class="font-mono text-xs uppercase tracking-[0.14em] text-[var(--muted)]">
          {professionalProjects.length} live
        </span>
      </div>
      <p class="m-0 max-w-[620px] text-sm text-[var(--muted)]">
        Core product work and full-stack applications built as part of client or team engagements.
      </p>

      <div class="mt-4 grid gap-6 md:grid-cols-1 lg:grid-cols-2">
        {professionalProjects.map((project) => (
          <ProjectCard
            name={project.name}
            description={project.description}
            tags={project.tags}
            live={project.live}
            code={project.code}
            caseStudy={project.caseStudy}
            image={project.image}
          />
        ))}
      </div>
    </div>

    <div class="mt-12 rounded-2xl border border-[var(--border)] bg-[rgba(253,246,238,0.55)] p-8 backdrop-blur-[20px] transition-colors duration-300 hover:border-[var(--accent)] dark:bg-[rgba(4,8,15,0.55)] md:p-10">
      <span class="eyebrow">Also worth a look</span>
      <h2 class="mb-3 mt-0 text-2xl font-semibold text-[var(--fg)] md:text-3xl">Freelance work</h2>
      <p class="mb-6 max-w-[560px] text-sm text-[var(--muted)] md:text-base">
        Contract and client engagements — independent builds across product, dashboard, and ed-tech work.
      </p>
      <a
        href="/freelance"
        class="inline-flex items-center gap-2 rounded-xl border border-[var(--accent)] bg-[var(--accent)] px-5 py-2.5 text-sm font-medium text-[var(--bg)] transition-all duration-300 hover:bg-[var(--accent-light)] hover:border-[var(--accent-light)]"
      >
        View freelance projects →
      </a>
    </div>
  </section>
</PageLayout>
