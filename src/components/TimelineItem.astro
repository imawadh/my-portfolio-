---
interface Props {
  type: 'work' | 'education';
  title: string;
  company: string;
  date: string;
  description: string;
}

const { type, title, company, date, description } = Astro.props;
const isWork = type === 'work';
---

<div class="relative rounded-2xl border border-[var(--border)] bg-[rgba(253,246,238,0.55)] p-6 backdrop-blur-[20px] transition-colors duration-300 hover:border-[var(--accent)] dark:bg-[rgba(4,8,15,0.55)] md:p-7">
  <div class="flex flex-wrap items-center justify-between gap-3">
    <span class={`inline-flex items-center gap-1.5 rounded-xl border px-2.5 py-1 font-mono text-[0.65rem] font-semibold uppercase tracking-[0.12em] ${isWork ? 'border-[var(--accent)] bg-[var(--accent)]/10 text-[var(--accent)]' : 'border-[var(--border)] bg-[var(--surface)] text-[var(--muted)]'}`}>
      <span class={`inline-block h-1.5 w-1.5 rounded-full ${isWork ? 'bg-[var(--accent)]' : 'bg-[var(--muted)]'}`}></span>
      {isWork ? 'Work' : 'Education'}
    </span>
    <span class="font-mono text-xs text-[var(--muted)]">{date}</span>
  </div>
  <h4 class="mt-4 mb-1 text-lg font-semibold text-[var(--fg)]">{title}</h4>
  <p class="m-0 text-sm font-medium text-[var(--accent)]">{company}</p>
  <p class="mt-3 mb-0 text-sm leading-relaxed text-[var(--muted)]">{description}</p>
</div>
