---
interface Props {
  date: string;
  title: string;
  issuer: string;
  details: string;
  url: string;
}

const { date, title, issuer, details, url } = Astro.props;
---

<a
  href={url}
  target="_blank"
  rel="noopener noreferrer"
  class="group flex flex-col gap-3 rounded-2xl border border-[var(--border)] bg-[rgba(253,246,238,0.55)] p-6 backdrop-blur-[20px] transition-all duration-300 hover:-translate-y-0.5 hover:border-[var(--accent)] dark:bg-[rgba(4,8,15,0.55)] md:flex-row md:items-center md:justify-between md:p-7"
  style="border-bottom: 1px solid var(--border);"
>
  <div class="flex flex-col gap-1.5">
    <span class="font-mono text-[0.7rem] uppercase tracking-[0.14em] text-[var(--accent)]">{date}</span>
    <h4 class="m-0 text-base font-semibold text-[var(--fg)] transition-colors duration-300 group-hover:text-[var(--accent)] md:text-lg">
      {title}
    </h4>
    <p class="m-0 text-sm font-medium text-[var(--fg)]">{issuer}</p>
    <p class="m-0 text-sm text-[var(--muted)]">{details}</p>
  </div>
  <span class="font-mono text-xs text-[var(--muted)] transition-colors duration-300 group-hover:text-[var(--accent)] md:text-sm">
    View certificate →
  </span>
</a>
