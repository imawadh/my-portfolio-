---
import { socials } from '../utils/socials';

const navItems = [
  { label: 'About', href: '/about' },
  { label: 'Skills', href: '/skills' },
  { label: 'Experience', href: '/experience' },
  { label: 'Projects', href: '/projects' },
  { label: 'Freelance', href: '/freelance' },
  { label: 'Certifications', href: '/certifications' },
  { label: 'Contact', href: '/contact' },
];
---

<footer class="border-t border-[var(--border)] bg-[rgba(253,246,238,0.82)] backdrop-blur-[24px] transition-all duration-300 dark:bg-[rgba(4,8,15,0.72)] dark:backdrop-blur-[20px]">
  <div class="container mx-auto px-6 pt-16 md:px-8 md:pt-24">
    <div class="flex flex-col gap-10 border-b border-[var(--border)] pb-14 md:flex-row md:items-end md:justify-between md:gap-16">
      <div class="max-w-2xl">
        <span class="eyebrow">Let's collaborate</span>
        <h2 class="m-0 mt-2 text-4xl font-semibold leading-[1.05] tracking-tight text-[var(--fg)] md:text-5xl lg:text-6xl">
          Have a project in mind?
          <br />
          <span class="text-[var(--accent)]">Let's build it together.</span>
        </h2>
      </div>

      <div class="flex flex-col gap-4 md:items-end">
        <a
          href="mailto:awadhkishorsingh241@gmail.com"
          class="font-mono text-sm text-[var(--muted)] no-underline transition-colors duration-300 hover:text-[var(--accent)]"
          style="border: none;"
        >
          awadhkishorsingh241@gmail.com
        </a>
        <a
          href="/contact"
          class="inline-flex items-center gap-2 rounded-xl border border-[var(--accent)] bg-[var(--accent)] px-5 py-2.5 text-sm font-medium text-[var(--bg)] no-underline transition-all duration-300 hover:bg-[var(--accent-light)] hover:border-[var(--accent-light)]"
          style="border-color: var(--accent);"
        >
          Get in touch →
        </a>
      </div>
    </div>

    <div class="grid gap-10 py-14 md:grid-cols-4 md:gap-8">
      <div class="md:col-span-2">
        <div class="inline-flex items-center gap-3">
          <svg
            class="h-5 w-5 text-[var(--accent)]"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            aria-hidden="true"
          >
            <line x1="12" y1="3" x2="12" y2="21"></line>
            <line x1="3" y1="12" x2="21" y2="12"></line>
            <line x1="5.6" y1="5.6" x2="18.4" y2="18.4"></line>
            <line x1="18.4" y1="5.6" x2="5.6" y2="18.4"></line>
          </svg>
          <span class="text-base font-semibold tracking-tight text-[var(--fg)]">Awadh Kishor Singh</span>
        </div>
        <p class="mt-4 max-w-md text-sm leading-relaxed text-[var(--muted)]">
          Full-stack and Gen AI developer crafting considered, end-to-end web products and
          agentic applications from Bengaluru. Currently interning at IAverse and studying Data
          Science at IIT Madras.
        </p>
        <div class="mt-6 inline-flex items-center gap-2 rounded-full border border-[var(--border)] bg-[var(--surface)]/40 py-1.5 pl-2.5 pr-3.5">
          <span class="relative inline-flex h-2 w-2">
            <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-[var(--accent)] opacity-60"></span>
            <span class="relative inline-flex h-2 w-2 rounded-full bg-[var(--accent)]"></span>
          </span>
          <span class="font-mono text-[0.65rem] uppercase tracking-[0.16em] text-[var(--muted)]">
            Available for new work
          </span>
        </div>
      </div>

      <div>
        <span class="eyebrow">Explore</span>
        <ul class="m-0 mt-3 flex list-none flex-col gap-2 p-0">
          {navItems.map((item) => (
            <li class="m-0">
              <a
                href={item.href}
                class="text-sm text-[var(--fg)] no-underline transition-colors duration-300 hover:text-[var(--accent)]"
                style="border: none;"
              >
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <span class="eyebrow">Elsewhere</span>
        <ul class="m-0 mt-3 flex list-none flex-col gap-2 p-0">
          {socials.map((social) => (
            <li class="m-0">
              <a
                href={social.url}
                title={social.label}
                target="_blank"
                rel="noopener noreferrer"
                class="group inline-flex items-center gap-1.5 text-sm text-[var(--fg)] no-underline transition-colors duration-300 hover:text-[var(--accent)]"
                style="border: none;"
              >
                <span>{social.label}</span>
                <span class="font-mono text-xs text-[var(--muted)] opacity-0 transition-opacity duration-300 group-hover:opacity-100">↗</span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>

  <div class="border-t border-[var(--border)] bg-[var(--surface)]/30">
    <div class="container mx-auto px-6 py-5 md:px-8">
      <p class="m-0 text-center font-mono text-[0.65rem] uppercase tracking-[0.16em] text-[var(--muted)] md:text-left">
        © 2026 Awadh Kishor Singh — All rights reserved
      </p>
    </div>
  </div>
</footer>
